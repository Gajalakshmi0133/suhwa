{
  "asl": {
    "name": "American Sign Language",
    "region": "United States, Canada, parts of Africa",
    "modules": [
      {
        "id": "intro",
        "title": "Introduction",
        "lessons": [
          {
            "id": "asl_intro_1",
            "title": "Welcome to ASL",
            "target": "HELLO",
            "instructions": [
              "Watch the orientation video.",
              "Learn about hand dominance.",
              "Understand facial expressions."
            ],
            "video_url": "/static/videos/asl/intro.mp4"
          }
        ]
      },
      {
        "id": "alphabet",
        "title": "Alphabet & Fingerspelling",
        "lessons": [
          {
            "id": "asl_alpha_a",
            "title": "Letter 'A'",
            "target": "A",
            "instructions": [
              "Close hand into a fist.",
              "Thumb on the side.",
              "Palm forward."
            ],
            "video_url": "/static/videos/asl/alpha_a.mp4"
          },
          {
            "id": "asl_alpha_b",
            "title": "Letter 'B'",
            "target": "B",
            "instructions": [
              "Open hand flat.",
              "Thumb across palm.",
              "Palm forward."
            ],
            "video_url": "/static/videos/asl/alpha_b.mp4"
          }
        ]
      },
      {
        "id": "numbers",
        "title": "Numbers Tutorial",
        "lessons": [
          {
            "id": "asl_num_0",
            "title": "Number '0'",
            "target": "0",
            "instructions": [
              "Form an 'O' shape with your fingers.",
              "Palm facing forward."
            ],
            "video_url": "/static/videos/asl/number_0.mp4"
          },
          {
            "id": "asl_num_1",
            "title": "Number '1'",
            "target": "1",
            "instructions": [
              "Index finger up.",
              "Palm facing inwards."
            ],
            "video_url": "/static/videos/asl/number_1.mp4"
          },
          {
            "id": "asl_num_2",
            "title": "Number '2'",
            "target": "2",
            "instructions": [
              "Index and middle fingers up.",
              "Palm facing inwards."
            ],
            "video_url": "/static/videos/asl/number_2.mp4"
          },
          {
            "id": "asl_num_3",
            "title": "Number '3'",
            "target": "3",
            "instructions": [
              "Thumb, index, and middle fingers out.",
              "Palm facing inwards."
            ],
            "video_url": "/static/videos/asl/number_3.mp4"
          },
          {
            "id": "asl_num_4",
            "title": "Number '4'",
            "target": "4",
            "instructions": [
              "Four fingers up.",
              "Thumb tucked in.",
              "Palm facing inwards."
            ],
            "video_url": "/static/videos/asl/number_4.mp4"
          },
          {
            "id": "asl_num_5",
            "title": "Number '5'",
            "target": "5",
            "instructions": [
              "All five fingers spread.",
              "Palm facing inwards."
            ],
            "video_url": "/static/videos/asl/number_5.mp4"
          },
          {
            "id": "asl_num_6",
            "title": "Number '6'",
            "target": "6",
            "instructions": [
              "Pinky and thumb touch.",
              "Other three fingers up.",
              "Palm facing forward."
            ],
            "video_url": "/static/videos/asl/number_6.mp4"
          },
          {
            "id": "asl_num_7",
            "title": "Number '7'",
            "target": "7",
            "instructions": [
              "Ring finger and thumb touch.",
              "Other three fingers up.",
              "Palm facing forward."
            ],
            "video_url": "/static/videos/asl/number_7.mp4"
          },
          {
            "id": "asl_num_8",
            "title": "Number '8'",
            "target": "8",
            "instructions": [
              "Middle finger and thumb touch.",
              "Other three fingers up.",
              "Palm facing forward."
            ],
            "video_url": "/static/videos/asl/number_8.mp4"
          },
          {
            "id": "asl_num_9",
            "title": "Number '9'",
            "target": "9",
            "instructions": [
              "Index finger and thumb touch.",
              "Other three fingers up.",
              "Palm facing forward."
            ],
            "video_url": "/static/videos/asl/number_9.mp4"
          }
        ]
      },
      {
        "id": "greetings",
        "title": "Basic Greetings",
        "lessons": [
          {
            "id": "asl_greet_hello",
            "title": "Hello",
            "target": "HELLO",
            "instructions": [
              "Hand at forehead.",
              "Move outwards like a salute."
            ],
            "video_url": "/static/videos/asl/hello.mp4"
          }
        ]
      },
      {
        "id": "words",
        "title": "Common Daily-Use Words",
        "lessons": [
          {
            "id": "asl_word_mother",
            "title": "Mother",
            "target": "MOTHER",
            "instructions": [
              "Thumb touches chin.",
              "Hand open."
            ],
            "video_url": "/static/videos/asl/mother.mp4"
          }
        ]
      },
      {
        "id": "sentences",
        "title": "Sentence Formation",
        "lessons": [
          {
            "id": "asl_sent_1",
            "title": "Simple Sentences",
            "target": "I LEARN SIGN",
            "instructions": [
              "Sign 'I'.",
              "Sign 'LEARN'.",
              "Sign 'SIGN'."
            ],
            "video_url": "/static/videos/asl/sentences.mp4"
          }
        ]
      }
    ],
